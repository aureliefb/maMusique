{% extends 'base.html.twig' %}

{% block title %}Admin - Artistes{% endblock %}

{% block body %}

    <div class="container">
    <h1 class="text-center my-4">Gestion des artistes & groupes</h1>
    <div class="my-4">
        <a href="#"><button type="submit" class="btn btn-sm btn-success">Nouveau</button></a>
    </div>

    <table class="table table-striped table-sm">
        <thead>
        <tr>
            {# <td>id</td> #}
            <td>Nom artiste /groupe</td>
            <td>Style</td>
            <td>Pays</td>
            <td>Je veux faire quoi ?</td>
        </tr>
        </thead>
        <tbody>
        {% for artist in artists %}
            <tr>
                {# <td>{{ artist.id }}</td>#}
                <td>{{ artist.nom }}</td>
                <td>{{ artist.style.style }}</td>
                <td><img src="{{ asset('/images/flags/'~artist.pays.code~'.jpg') }}" style="width:1.6rem;" alt="drapeau {{ artist.pays.pays }}"> {{ artist.pays.pays }}</td>
                <td>
                    <a href="{{ path('admin_edit_artist', {'id':artist.id}) }}"><button class="btn btn-warning btn-sm">Editer</button></a>
                    <form method="post" action="" style="display:inline-block;">
                        <input type="hidden" name="_method" value="DELETE">
                        <input type="hidden" name="_token" value="">
                        <button type="submit" class="btn btn-danger btn-sm">Supprimer</button>
                    </form>
                    <!--a href=""><button class="btn btn-danger btn-sm">Supprimer</button></a-->
                    <a href="{{ path('ficheArtiste', {'id':artist.id}) }}"><button type="button" class="btn btn-primary btn-sm">Voir</button></a>
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    </div>

{% endblock %}
